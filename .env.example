# RXIncredible Backend Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env file to version control!

# =============================================
# REQUIRED - JWT Configuration
# =============================================
# Generate a secure 256-bit (32 character) random string
# Use: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-min-32-characters-long

# JWT token expiration in milliseconds (15 minutes = 900000)
JWT_EXPIRATION=900000

# =============================================
# REQUIRED - Database Configuration
# =============================================
DB_URL=jdbc:mysql://your-db-host:3306/rxincredible?useSSL=true&requireSSL=true&serverTimezone=UTC
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# =============================================
# REQUIRED - Email Configuration
# =============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# =============================================
# OPTIONAL - Default Users (Set to 'false' in production)
# =============================================
APP_INIT_DEFAULT_USERS=false
DEFAULT_ADMIN_PASSWORD=change-this-secure-password
DEFAULT_DOCTOR_PASSWORD=change-this-secure-password
DEFAULT_ACCOUNTANT_PASSWORD=change-this-secure-password

# =============================================
# OPTIONAL - CORS Origins (comma-separated for production)
# =============================================
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================
# OPTIONAL - Network / Frontend Configuration
# =============================================
SERVER_ADDRESS=0.0.0.0
SERVER_PORT=8090
APP_FRONTEND_URL=http://your-frontend-host:5180

# =============================================
# OPTIONAL - Razorpay Configuration
# =============================================
# Use rzp_test_* with RAZORPAY_TEST_MODE=true for testing
# Use rzp_live_* with RAZORPAY_TEST_MODE=false for production
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_TEST_MODE=true
RAZORPAY_MOCK_MODE=false
